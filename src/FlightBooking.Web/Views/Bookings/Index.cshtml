@model IEnumerable<Booking>
@{ViewData["Title"]="Резервации";}
<section class="page-head"><span class="eyebrow">МОИТЕ ПЪТУВАНИЯ</span><h1>Управление на резервации</h1><p>Потърсете по имейл или управлявайте всички резервации.</p><form method="get" class="inline-search"><input name="email" value="@ViewBag.Email" type="email" placeholder="Имейл на пътника"/><button class="primary small">Покажи</button><a class="secondary" asp-action="Index">Изчисти</a></form><a class="primary small" asp-action="Create">+ Нова резервация</a></section>
<section class="content-wrap"><div class="booking-list">@foreach(var b in Model){<article class="booking-card"><div><span class="eyebrow">@b.BookingCode</span><h3>@b.Flight.DepartureAirport.Code → @b.Flight.ArrivalAirport.Code</h3><p>@b.Passenger.FullName · @b.Flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")</p></div><div><span class="status">@b.Status</span><b>@b.TotalPrice.ToString("0.00") €</b></div><div class="actions"><a asp-action="Details" asp-route-id="@b.Id">Детайли</a><a asp-action="Edit" asp-route-id="@b.Id">Редакция</a><a asp-action="Delete" asp-route-id="@b.Id">Отказ</a></div></article>}</div></section>
