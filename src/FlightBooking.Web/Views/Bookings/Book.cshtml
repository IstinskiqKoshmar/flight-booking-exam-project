@model BookingRequestViewModel
@{ViewData["Title"]="Резервация";}
<section class="page-head compact"><span class="eyebrow">СТЪПКА 1 ОТ 1</span><h1>Данни за пътника</h1></section><section class="booking-layout"><aside class="trip-summary"><span>@Model.Flight.Airline.Name</span><h2>@Model.Flight.DepartureAirport.Code → @Model.Flight.ArrivalAirport.Code</h2><p>@Model.Flight.DepartureTime.ToString("dd.MM.yyyy · HH:mm") — @Model.Flight.ArrivalTime.ToString("HH:mm")</p><hr/><div><span>Полет</span><b>@Model.Flight.FlightNumber</b></div><div><span>Цена за човек</span><b>@Model.Flight.Price.ToString("0.00") €</b></div></aside><form method="post" class="form-page"><input asp-for="FlightId" type="hidden"/><div asp-validation-summary="ModelOnly" class="validation"></div><div class="form-grid"><label>Три имена<input asp-for="FullName" required/></label><label>Имейл<input asp-for="Email" type="email" required/></label><label>Телефон<input asp-for="Phone" required/></label><label>Номер на паспорт<input asp-for="PassportNumber" required/></label><label>Националност<input asp-for="Nationality" required/></label><label>Дата на раждане<input asp-for="BirthDate" type="date" required/></label><label>Брой пътници<input asp-for="PassengerCount" type="number" min="1" max="9"/></label><label>Вид пътуване<select asp-for="TripType"><option>Еднопосочен</option><option>Двупосочен</option></select></label><label class="wide">Бележки<textarea asp-for="Notes"></textarea></label></div><button class="primary">Потвърди резервацията</button></form></section>
