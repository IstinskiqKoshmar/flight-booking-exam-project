@model Booking
<div asp-validation-summary="ModelOnly" class="validation"></div><div class="form-grid"><label>Код<input asp-for="BookingCode"/></label><label>Пътник<select asp-for="PassengerId" asp-items="ViewBag.PassengerId"></select></label><label>Полет<select asp-for="FlightId" asp-items="ViewBag.FlightId"></select></label><label>Брой пътници<input asp-for="PassengerCount"/></label><label>Вид<select asp-for="TripType"><option>Еднопосочен</option><option>Двупосочен</option></select></label><label>Дата<input asp-for="BookingDate" type="datetime-local"/></label><label>Обща цена<input asp-for="TotalPrice" type="number" step="0.01"/></label><label>Статус<select asp-for="Status"><option>Чакаща</option><option>Потвърдена</option><option>Отменена</option><option>Приключена</option></select></label><label class="wide">Бележки<textarea asp-for="Notes"></textarea></label></div><button class="primary">Запази</button> <a class="secondary" asp-action="Index">Отказ</a>
