@model Booking
@{ViewData["Title"]="Резервация";}<section class="page-head"><span class="eyebrow">РЕЗЕРВАЦИЯ @Model.BookingCode</span><h1>@Model.Flight.DepartureAirport.City → @Model.Flight.ArrivalAirport.City</h1><p>@Model.Passenger.FullName</p></section><section class="details-card"><dl><div><dt>Полет</dt><dd>@Model.Flight.FlightNumber</dd></div><div><dt>Дата и час</dt><dd>@Model.Flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")</dd></div><div><dt>Пътници</dt><dd>@Model.PassengerCount</dd></div><div><dt>Вид</dt><dd>@Model.TripType</dd></div><div><dt>Статус</dt><dd>@Model.Status</dd></div><div><dt>Цена</dt><dd>@Model.TotalPrice.ToString("0.00") €</dd></div><div><dt>Имейл</dt><dd>@Model.Passenger.Email</dd></div><div><dt>Бележки</dt><dd>@Model.Notes</dd></div></dl><a class="secondary" asp-action="Index">Назад</a></section>
