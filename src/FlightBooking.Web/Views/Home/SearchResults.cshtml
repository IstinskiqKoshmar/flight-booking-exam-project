@model SearchResultsViewModel
@{ViewData["Title"]="Резултати";}
<section class="page-head"><span class="eyebrow">РЕЗУЛТАТИ ОТ ТЪРСЕНЕТО</span><h1>@Model.From → @Model.To</h1><p>@Model.Date.ToString("dd.MM.yyyy") · @Model.Passengers пътник/ци · @(Model.TripType=="roundtrip"?"двупосочен":"еднопосочен")</p></section>
<section class="content-wrap"><form method="get" class="filters"><input type="hidden" name="from" value="@Model.From"/><input type="hidden" name="to" value="@Model.To"/><input type="hidden" name="date" value="@Model.Date.ToString("yyyy-MM-dd")"/><input type="hidden" name="returnDate" value="@Model.ReturnDate?.ToString("yyyy-MM-dd")"/><input type="hidden" name="passengers" value="@Model.Passengers"/><input type="hidden" name="tripType" value="@Model.TripType"/><label>Сортиране<select name="sort"><option value="price">Най-ниска цена</option><option value="duration">Най-кратко време</option><option value="departure">Най-ранно излитане</option></select></label><label>Авиокомпания<select name="airlineId"><option value="">Всички</option>@foreach(var a in Model.Airlines){<option value="@a.Id">@a.Name</option>}</select></label><label class="check"><input type="checkbox" name="directOnly" value="true"/> Само директни</label><button class="secondary">Приложи</button></form>
<h2>Полет натам <span class="count">@Model.OutboundFlights.Count резултата</span></h2>@await Html.PartialAsync("_FlightResults",Model.OutboundFlights)
@if(Model.TripType=="roundtrip"){<h2>Обратен полет <span class="count">@Model.ReturnFlights.Count резултата</span></h2>@await Html.PartialAsync("_FlightResults",Model.ReturnFlights)}
</section>
