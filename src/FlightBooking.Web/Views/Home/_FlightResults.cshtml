@model IReadOnlyList<Flight>
@if(Model.Count==0){<div class="empty">Няма полети по избраните критерии. Опитайте друга дата или маршрут.</div>}
@foreach(var f in Model){<article class="result-row"><div class="airline"><span class="airline-logo">@f.Airline.IataCode</span><div><b>@f.Airline.Name</b><small>@f.FlightNumber</small></div></div><div class="time"><b>@f.DepartureTime.ToString("HH:mm")</b><span>@f.DepartureAirport.Code</span></div><div class="duration"><span>@f.Duration.ToString(@"h\ч\ mm\м")</span><hr/><small>@(f.HasStopover?"1 прекачване":"Директен")</small></div><div class="time"><b>@f.ArrivalTime.ToString("HH:mm")</b><span>@f.ArrivalAirport.Code</span></div><div class="result-price"><small>за човек</small><b>@f.Price.ToString("0") €</b><a class="primary small" asp-controller="Bookings" asp-action="Book" asp-route-flightId="@f.Id">Избери</a></div></article>}
