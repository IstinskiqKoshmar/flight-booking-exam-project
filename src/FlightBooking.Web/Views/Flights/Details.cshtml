@model Flight
@{ViewData["Title"]="Детайли";}<section class="page-head"><span class="eyebrow">@Model.Airline.Name</span><h1>@Model.FlightNumber</h1><p>@Model.DepartureAirport.City → @Model.ArrivalAirport.City</p></section><section class="details-card"><div class="big-route"><div><b>@Model.DepartureTime.ToString("HH:mm")</b><strong>@Model.DepartureAirport.Code</strong><span>@Model.DepartureAirport.Name</span></div><div>✈<hr/><span>@Model.Duration.ToString(@"h\ч\ mm\м")</span></div><div><b>@Model.ArrivalTime.ToString("HH:mm")</b><strong>@Model.ArrivalAirport.Code</strong><span>@Model.ArrivalAirport.Name</span></div></div><dl><div><dt>Дата</dt><dd>@Model.DepartureTime.ToString("dd.MM.yyyy")</dd></div><div><dt>Статус</dt><dd>@Model.Status</dd></div><div><dt>Изход</dt><dd>@Model.Gate</dd></div><div><dt>Свободни места</dt><dd>@Model.AvailableSeats</dd></div><div><dt>Цена</dt><dd>@Model.Price.ToString("0.00") €</dd></div></dl><a class="primary" asp-controller="Bookings" asp-action="Book" asp-route-flightId="@Model.Id">Резервирай</a></section>
