@model Flight
<div asp-validation-summary="ModelOnly" class="validation"></div><div class="form-grid"><label>Номер<input asp-for="FlightNumber" required/></label><label>Авиокомпания<select asp-for="AirlineId" asp-items="ViewBag.AirlineId"></select></label><label>Начално летище<select asp-for="DepartureAirportId" asp-items="ViewBag.DepartureAirportId"></select></label><label>Крайно летище<select asp-for="ArrivalAirportId" asp-items="ViewBag.ArrivalAirportId"></select></label><label>Излитане<input asp-for="DepartureTime" type="datetime-local"/></label><label>Кацане<input asp-for="ArrivalTime" type="datetime-local"/></label><label>Цена (€)<input asp-for="Price" type="number" step="0.01"/></label><label>Свободни места<input asp-for="AvailableSeats" type="number"/></label><label>Статус<select asp-for="Status"><option>По разписание</option><option>Навреме</option><option>Закъснял</option><option>Отменен</option><option>Излетял</option><option>Кацнал</option></select></label><label>Изход<input asp-for="Gate"/></label><label class="check"><input asp-for="HasStopover"/> Има прекачване</label></div><button class="primary" type="submit">Запази</button> <a class="secondary" asp-action="Index">Отказ</a>
