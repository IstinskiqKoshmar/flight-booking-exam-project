@model IEnumerable<Flight>
@{ViewData["Title"]="Полети";}
<section class="page-head"><span class="eyebrow">РАЗПИСАНИЕ И СТАТУС</span><h1>Всички полети</h1><p>Административен изглед за управление и проследяване.</p><a class="primary small" asp-action="Create">+ Добави полет</a></section>
<section class="content-wrap"><div class="status-links"><a asp-action="Index">Всички</a><a asp-action="Index" asp-route-status="Навреме">Навреме</a><a asp-action="Index" asp-route-status="Закъснял">Закъснели</a><a asp-action="Index" asp-route-status="Отменен">Отменени</a><a asp-action="Index" asp-route-status="Кацнал">Кацнали</a></div><div class="table-wrap"><table><thead><tr><th>Полет</th><th>Маршрут</th><th>Излитане</th><th>Цена</th><th>Места</th><th>Статус</th><th></th></tr></thead><tbody>@foreach(var f in Model){<tr><td><b>@f.FlightNumber</b><small>@f.Airline.Name</small></td><td>@f.DepartureAirport.Code → @f.ArrivalAirport.Code</td><td>@f.DepartureTime.ToString("dd.MM HH:mm")</td><td>@f.Price.ToString("0") €</td><td>@f.AvailableSeats</td><td><span class="status">@f.Status</span></td><td class="actions"><a asp-action="Details" asp-route-id="@f.Id">Преглед</a><a asp-action="Edit" asp-route-id="@f.Id">Редакция</a><a asp-action="Delete" asp-route-id="@f.Id">Изтриване</a></td></tr>}</tbody></table></div></section>
